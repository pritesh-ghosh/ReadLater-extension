{
  "manifest_version": 3,
  "name": "ReadLater.md",
  "version": "1.0",
  "description": "Convert any article into a clean Markdown file and save it locally.",
  "permissions": [
    "activeTab",
    "downloads"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["readability.js", "turndown.js", "content.js"]
    }
  ]
}